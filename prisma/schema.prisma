generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  active
  inactive
  on_leave
}

model Employee {
  id                   String   @id @default(cuid())
  employeeId           String   @unique
  firstName            String
  lastName             String
  email                String   @unique
  phone                String
  department           String    
  designation          String?
  salary               Float
  status               String
  attendancePercentage Float    @default(0)
  address              String     
  joiningDate          DateTime
  imageUrl             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}